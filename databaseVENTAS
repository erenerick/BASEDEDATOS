CREATE DATABASE VENTAS
use ventas

CREATE TABLE CLIENTES
(
codcliente char(5) not null,
nomcliente varchar(20) null,
apepcliente varchar(20) null,
apemcliente varchar(20) null,
razonsocial varchar(30) null,
ruc char(11) null,
constraint pk_cliente primary key (codcliente)
)
CREATE TABLE TIPOPRODU
(
codtipo char(3) not null,
nomtipo varchar(20) not null,
constraint pk_tipo primary key(codtipo)
)
CREATE TABLE LOTE
(
codlote char(5) not null,
deslote varchar(20) not null,
constraint pk_lote primary key(codlote)
)
CREATE TABLE MARCA
(
codmarca char(5) not null,
desmarca varchar(20) not null,
constraint pk_marca primary key(codmarca)
)
CREATE TABLE COMPROBANTE
(
codventa char(5) not null,
fechemisi datetime not null,
montototal decimal(9,2) not null,
cantidadtotal smallint not null,
igv decimal(9,2) not null,
codcliente char(5) not null,
subtotal decimal(9,2) not null,
constraint pk_compro primary key(codventa),
constraint fk_compro foreign key(codcliente) references CLIENTES(codcliente)
)
CREATE TABLE PRODUCTO
(
codprod char(5) not null,
nomprod varchar(20) not null,
precio decimal(8,2) not null,
codtipo char(3) not null,
stock smallint not null,
codlote char(5) not null,
codmarca char(5) not null,
constraint pk_producto primary key(codprod),
constraint fk_tipo foreign key(codtipo) references TIPOPRODU(codtipo),
constraint fk_lote foreign key(codlote) references LOTE(codlote),
constraint fk_marca foreign key(codmarca) references MARCA(codmarca)
)
CREATE TABLE COMPRO_PRODU
(
codventa char(5) not null,
codprod char(5) not null,
cantxprod smallint not null,
subtotalxprod decimal(9,2) not null,
constraint fk_prod1 foreign key(codventa) references COMPROBANTE(codventa),
constraint fk_prod2 foreign key(codprod) references PRODUCTO(codprod),
constraint pk_compuesta primary key(codventa,codprod)
)
